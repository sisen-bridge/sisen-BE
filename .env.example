# The infrastructure layer injects ONE of the following at runtime.

# Option A — direct connection string (e.g. via IP-allowlisted Cloud SQL)
# DATABASE_URL=postgresql+pg8000://user:password@host:5432/dbname

# Option B — Cloud SQL Unix socket (Cloud Run + Cloud SQL Auth Proxy)
# INSTANCE_CONNECTION_NAME=project:region:instance
# DB_USER=
# DB_PASS=
# DB_NAME=
